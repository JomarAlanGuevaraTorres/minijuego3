GameState="*uid://cbope0t84e52k"
SceneSwitcher="*uid://c4gllhmqqbuju"
Transitions="*uid://b7wrvr38fukri"
Settings="*uid://cpxr1vvlcolfw"
PauseOverlay="*uid://bo2gd4sehdugm"
